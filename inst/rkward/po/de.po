msgid "Proportion Dimension (Calculates %)"
msgstr "Proportionsdimension (Berechnet %)"

msgid "Output"
msgstr "Ausgabe"

msgid "<b>Note:</b> Bubble size (Population Total) is calculated automatically based on the survey weights."
msgstr "<b>Hinweis:</b> Die Blasengröße (Gesamtbevölkerung) wird automatisch anhand der Umfragegewichte berechnet."

