msgid "Data preparation and generation of animated bubble charts (Gapminder style) using srvyr and gganimate."
msgstr "Datenvorbereitung und Erstellung animierter Blasendiagramme (Gapminder-Stil) mit srvyr und gganimate."

msgid "Survey"
msgstr "Umfragen"

msgid "Graphs"
msgstr "Grafiken"

msgid "Animations"
msgstr "Animationen"

msgid "1. Data Prep for Animation"
msgstr "1. Datenvorbereitung für Animation"

msgid "Data Prep for Animation (srvyr)"
msgstr "Datenvorbereitung für Animation (srvyr)"

msgid "Survey Design Object"
msgstr "Umfrage-Design-Objekt"

msgid "1. Time Variable (e.g., year)"
msgstr "1. Zeitvariable (z. B. Jahr)"

msgid "2. Group Variable (e.g., ent)"
msgstr "2. Gruppenvariable (z. B. Bundesland)"

msgid "3. Y-Axis: Numeric Variable for Mean (e.g., ingocup)"
msgstr "3. Y-Achse: Numerische Variable für Mittelwert (z. B. Einkommen)"

msgid "4. X-Axis: Categorical Variable for % (e.g., seg_soc)"
msgstr "4. X-Achse: Kategoriale Variable für % (z. B. Sozialversicherung)"

msgid "Target Category Level for % (e.g., Sin acceso)"
msgstr "Zielkategorie-Ebene für % (z. B. Kein Zugang)"

msgid "Optional: dplyr::filter condition (e.g., clase1 == 'Población económicamente activa')"
msgstr "Optional: dplyr::filter-Bedingung (z. B. clase1 == 'Erwerbsbevölkerung')"

msgid "Save summarized table as"
msgstr "Zusammengefasste Tabelle speichern als"

