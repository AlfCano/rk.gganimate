msgstr "Préparation des Données pour l'Animation (srvyr)"

msgid "Survey Design Object"
msgstr "Objet de Plan de Sondage"

msgid "1. Time Variable (e.g., year)"
msgstr "1. Variable de Temps (ex., année)"

msgid "2. Group Variable (e.g., ent)"
msgstr "2. Variable de Groupe (ex., état)"

msgid "3. Y-Axis: Numeric Variable for Mean (e.g., ingocup)"
msgstr "3. Axe Y: Variable Numérique pour Moyenne (ex., revenu)"

msgid "4. X-Axis: Categorical Variable for % (e.g., seg_soc)"
msgstr "4. Axe X: Variable Catégorielle pour % (ex., sécurité sociale)"

msgid "Target Category Level for % (e.g., Sin acceso)"
msgstr "Niveau de Catégorie Cible pour % (ex., Sans accès)"

