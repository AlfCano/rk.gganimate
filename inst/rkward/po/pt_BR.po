msgstr "Largura (px)"

msgid "Height (px)"
msgstr "Altura (px)"

msgid "Save GIF as"
msgstr "Salvar GIF como"

msgid "Animation Settings"
msgstr "Configurações de Animação"

msgid "Dimensions"
msgstr "Dimensões"

