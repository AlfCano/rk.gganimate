msgstr "Storytelling: Acompanhar Bolhas"

msgid "Labels & Theme"
msgstr "Rótulos e Tema"

msgid "Frames per second (FPS)"
msgstr "Quadros por segundo (FPS)"

msgid "Duration (Seconds)"
msgstr "Duração (Segundos)"

