msgid "Data preparation and generation of animated bubble charts (Gapminder style) using srvyr and gganimate."
msgstr "Preparación de datos y generación de gráficos de burbujas animados (estilo Gapminder) usando srvyr y gganimate."

msgid "Survey"
msgstr "Encuestas"

msgid "Graphs"
msgstr "Gráficos"

msgid "Animations"
msgstr "Animaciones"

msgid "1. Data Prep for Animation"
msgstr "1. Preparación de Datos para Animación"

msgid "Data Prep for Animation (srvyr)"
msgstr "Preparación de Datos para Animación (srvyr)"

msgid "Survey Design Object"
msgstr "Objeto de Diseño de Encuesta"

msgid "1. Time Variable (e.g., year)"
msgstr "1. Variable de Tiempo (ej., año)"

msgid "2. Group Variable (e.g., ent)"
msgstr "2. Variable de Agrupación (ej., estado)"

msgid "3. Y-Axis: Numeric Variable for Mean (e.g., ingocup)"
msgstr "3. Eje Y: Variable Numérica para Promedio (ej., ingresos)"

msgid "4. X-Axis: Categorical Variable for % (e.g., seg_soc)"
msgstr "4. Eje X: Variable Categórica para % (ej., seguro social)"

msgid "Target Category Level for % (e.g., Sin acceso)"
msgstr "Nivel de Categoría Objetivo para % (ej., Sin acceso)"

msgid "Optional: dplyr::filter condition (e.g., clase1 == 'Población económicamente activa')"
msgstr "Opcional: Condición dplyr::filter (ej., clase1 == 'PEA')"

