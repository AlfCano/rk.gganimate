msgstr "Métricas (X e Y)"

msgid "Continuous Dimension (Calculates Mean)"
msgstr "Dimensión Continua (Calcula el Promedio)"

msgid "Proportion Dimension (Calculates %)"
msgstr "Dimensión de Proporción (Calcula el %)"

msgid "Output"
msgstr "Salida"

msgid "<b>Note:</b> Bubble size (Population Total) is calculated automatically based on the survey weights."
msgstr "<b>Nota:</b> El tamaño de la burbuja (Población Total) se calcula automáticamente basado en los ponderadores."

